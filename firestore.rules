rules_version = '2';
// Deploy: Firebase Console → Firestore → Rules, atau `firebase deploy --only firestore:rules`
service cloud.firestore {
  match /databases/{database}/documents {
    match /sellerApplications/{applicationId} {
      // Pengguna login boleh mengajukan (email harus sama dengan akun Firebase).
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'submittedAt', 'storeName', 'storeDescription', 'email', 'phone',
          'streetAddress', 'city', 'agreedToTerms', 'status'
        ])
        && request.resource.data.status == 'pending'
        && request.resource.data.email == request.auth.token.email;

      // Baca daftar pengajuan (panel admin di app + sinkron peta).
      allow read: if request.auth != null;

      // Admin app memperbarui status (setujui / tolak).
      allow update: if request.auth != null;

      allow delete: if false;
    }
  }
}

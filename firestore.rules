rules_version = '2';
// Deploy: Firebase Console → Firestore → Rules, atau `firebase deploy --only firestore:rules`
//
// Email admin HARUS sama dengan `kAppAdminEmailLocal` di lib/config/app_admin_local.dart
service cloud.firestore {
  match /databases/{database}/documents {
    function adminEmail() {
      return 'danielrionaldo_2428250018@mhs.mdp.ac.id';
    }

    function adminUid() {
      return 'S3zzmx2SJ5WDN8bhzJHep5BTepy1';
    }

    function isAdmin() {
      return request.auth != null
        && (request.auth.token.email == adminEmail()
            || request.auth.uid == adminUid());
    }

    match /sellerApplications/{applicationId} {
      // Pemohon mengajukan (email = akun login, status pending).
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'submittedAt', 'storeName', 'storeDescription', 'email', 'phone',
          'streetAddress', 'city', 'agreedToTerms', 'status'
        ])
        && request.resource.data.status == 'pending'
        && request.resource.data.email == request.auth.token.email;

      // Admin / pemohon sendiri / toko disetujui (profil & peta untuk pembeli).
      allow read: if isAdmin()
        || (request.auth != null
            && resource.data.email == request.auth.token.email)
        || resource.data.status == 'approved';

      // Admin: setujui / tolak. Pemilik toko disetujui: edit profil toko saja.
      allow update: if isAdmin()
        || (request.auth != null
            && resource.data.email == request.auth.token.email
            && resource.data.status == 'approved'
            && request.resource.data.email == resource.data.email
            && request.resource.data.status == 'approved'
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly([
                  'storeName', 'storeDescription', 'phone',
                  'streetAddress', 'city', 'logoPath', 'logoUrl',
                  'latitude', 'longitude'
                ]));

      allow delete: if isAdmin()
        || (request.auth != null
            && resource.data.email == request.auth.token.email
            && resource.data.status == 'approved');
    }
  }
}
